<view class="calendar-wrap">
  <view class="nav-row">
    <view class="nav-btn" bindtap="prevMonth"><text class="nav-arrow">‹</text></view>
    <text class="nav-title">{{monthTitle}}</text>
    <view class="nav-btn" bindtap="nextMonth"><text class="nav-arrow">›</text></view>
  </view>
  <view class="week-row">
    <text wx:for="{{weekDays}}" wx:key="*this" class="weekday">{{item}}</text>
  </view>
  <view class="grid">
    <view wx:for="{{cells}}" wx:key="key" class="cell {{item.hasTasks ? 'has-tasks' : ''}} {{item.allDone ? 'all-done' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}" data-date="{{item.date}}" bindtap="onDayTap">
      <text wx:if="{{item.day}}" class="day-text {{item.isSelected ? 'selected-text' : ''}} {{item.allDone && !item.isSelected ? 'done-text' : ''}}">{{item.day}}</text>
      <view wx:if="{{item.hasTasks}}" class="dot-row">
        <view class="dot {{item.allDone ? 'dot-done' : ''}}"></view>
        <text class="count {{item.isSelected ? 'selected-text' : ''}}">{{item.doneText}}</text>
      </view>
    </view>
  </view>
</view>
