/* Global styles */
page {
  background-color: #F5F1E8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #1E2A24;
  font-size: 28rpx;
  line-height: 1.5;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-padding {
  padding: 44rpx;
  padding-top: 128rpx;
}

/* Common components */
.btn-primary {
  background-color: #1E2A24;
  color: #FFF8EA;
  border-radius: 16rpx;
  min-height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
}

.btn-secondary {
  border: 2rpx solid #D8CEBC;
  background-color: #FFFCF4;
  color: #1E2A24;
  border-radius: 16rpx;
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
}

.label {
  color: #2D332F;
  font-size: 28rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
}

.card {
  border: 2rpx solid #D8CEBC;
  border-radius: 16rpx;
  background-color: #FFFCF4;
  padding: 28rpx;
}

.text-muted {
  color: #625B4D;
  font-size: 26rpx;
}

.text-secondary {
  color: #817767;
  font-size: 24rpx;
}

.accent {
  color: #2F8F7B;
}
