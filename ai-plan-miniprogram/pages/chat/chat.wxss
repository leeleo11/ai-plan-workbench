.chat-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #FFFCF4;
  border-bottom: 2rpx solid #D8CEBC;
}

.chat-header-emoji {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.chat-header-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #1E2A24;
}

.chat-body {
  flex: 1;
  height: 0;
  background-color: #F5F1E8;
}

.chat-messages {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  min-height: 100%;
}

.chat-input-area {
  background-color: #FFFCF4;
  border-top: 2rpx solid #D8CEBC;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.text-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chat-text-input {
  flex: 1;
  background-color: #F5F1E8;
  border: 2rpx solid #D8CEBC;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  color: #1E2A24;
}

.send-btn {
  background-color: #24352F;
  border-radius: 12rpx;
  padding: 18rpx 32rpx;
}

.send-btn-text {
  color: #FFF8EA;
  font-size: 28rpx;
  font-weight: 700;
}

.quick-buttons {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.quick-btn {
  flex: 1;
  min-width: 0;
  background-color: #F5F1E8;
  border: 2rpx solid #D8CEBC;
  border-radius: 12rpx;
  padding: 22rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #1E2A24;
}

.quick-btn:active {
  background-color: #24352F;
  color: #FFF8EA;
  border-color: #24352F;
}
