.generating-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.generating-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  position: relative;
}

.spinner-ring {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #D8CEBC;
  border-top-color: #2F8F7B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.status-text {
  font-size: 30rpx;
  color: #625B4D;
  text-align: center;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.error-emoji {
  font-size: 80rpx;
}

.error-text {
  font-size: 28rpx;
  color: #625B4D;
  text-align: center;
}

.retry-btn {
  width: 300rpx;
  margin-top: 16rpx;
}
