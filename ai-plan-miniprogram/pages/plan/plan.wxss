.plan-header {
  padding: 44rpx;
  padding-top: 32rpx;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-arrow {
  font-size: 48rpx;
  font-weight: 900;
  color: #1E2A24;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  color: #625B4D;
  font-weight: 700;
}

.pet-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FFFCF4;
  border: 2rpx solid #D8CEBC;
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
}

.pet-emoji {
  font-size: 32rpx;
}

.pet-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #1E2A24;
}

.plan-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #1E2A24;
  display: block;
  line-height: 1.3;
}

/* Summary band */
.summary-band {
  margin: 0 44rpx 32rpx;
  background: #24352F;
  border-radius: 16rpx;
  padding: 32rpx;
}

.summary-top {
  margin-bottom: 16rpx;
}

.summary-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #2F8F7B;
}

.summary-text {
  font-size: 26rpx;
  color: #FFF8EA;
  line-height: 1.6;
  display: block;
  margin-bottom: 20rpx;
}

.summary-links {
  display: flex;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.summary-link {
  font-size: 24rpx;
  color: #2F8F7B;
  font-weight: 700;
  text-decoration: underline;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: #2F8F7B;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-percent {
  font-size: 26rpx;
  font-weight: 800;
  color: #FFF8EA;
  min-width: 72rpx;
  text-align: right;
}

.stats-row {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 900;
  color: #FFF8EA;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 248, 234, 0.6);
}

/* Phase rail */
.phase-rail {
  padding: 0 44rpx 32rpx;
  white-space: nowrap;
}

.phase-card {
  display: inline-flex;
  flex-direction: column;
  width: 380rpx;
  background: #FFFCF4;
  border: 2rpx solid #D8CEBC;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-right: 20rpx;
  vertical-align: top;
  box-sizing: border-box;
}

.phase-index {
  font-size: 22rpx;
  font-weight: 800;
  color: #2F8F7B;
  margin-bottom: 8rpx;
}

.phase-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1E2A24;
  margin-bottom: 8rpx;
}

.phase-date {
  font-size: 22rpx;
  color: #625B4D;
  margin-bottom: 12rpx;
}

.phase-objective {
  font-size: 24rpx;
  color: #625B4D;
  line-height: 1.5;
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Calendar header */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 44rpx;
  margin-bottom: 20rpx;
}

.calendar-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1E2A24;
}

.today-btn {
  background: #FFFCF4;
  border: 2rpx solid #D8CEBC;
  border-radius: 12rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #1E2A24;
}

/* Calendar section */
.calendar-section {
  padding: 0 44rpx 32rpx;
}

/* Task panel */
.task-panel {
  padding: 0 44rpx 80rpx;
}

.task-date-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #625B4D;
  margin-bottom: 20rpx;
  display: block;
}

.empty-tasks {
  background: #FFFCF4;
  border: 2rpx solid #D8CEBC;
  border-radius: 16rpx;
  padding: 48rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #625B4D;
}

.task-card {
  display: flex;
  background: #FFFCF4;
  border: 2rpx solid #D8CEBC;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.task-left {
  margin-right: 24rpx;
  padding-top: 4rpx;
}

.checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #D8CEBC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.checkbox-done {
  background: #2F8F7B;
  border-color: #2F8F7B;
}

.check-mark {
  color: #FFF8EA;
  font-size: 28rpx;
  font-weight: 900;
}

.task-body {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1E2A24;
  display: block;
  margin-bottom: 8rpx;
}

.task-done {
  text-decoration: line-through;
  color: #817767;
}

.task-desc {
  font-size: 24rpx;
  color: #625B4D;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #817767;
}

.meta-done {
  font-size: 22rpx;
  color: #2F8F7B;
  font-weight: 700;
}
